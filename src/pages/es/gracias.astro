---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Gracias — Marco Sánchez Sorondo"
  description="Recibí tu aplicación."
>
  <section class="max-w-prose mx-auto px-4 py-24 text-center">
    <p class="text-xs uppercase tracking-[0.2em] text-ink-mute mb-6">Aplicación recibida</p>
    <h1 class="font-display text-4xl md:text-5xl leading-tight">¡Gracias!</h1>
    <p class="mt-6 text-lg text-ink-soft max-w-xl mx-auto leading-relaxed">
      Recibí tu aplicación. Te respondo en las próximas 48 horas con próximos pasos.
    </p>
    <p class="mt-10 text-sm">
      <a href="/es/" class="underline underline-offset-4 hover:text-ink">← Volver al inicio</a>
    </p>
  </section>
</BaseLayout>
