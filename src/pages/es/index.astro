---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import BlogCard from '../../components/BlogCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import LogoStrip from '../../components/LogoStrip.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import { getCollection } from 'astro:content';
import { t, route, localizedPath } from '../../i18n/utils';

const lang = 'es' as const;
const tr = t(lang);

const projects = (await getCollection('projects', (p) => p.id.startsWith('es/') && p.data.featured && !p.data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('blog', (p) => p.id.startsWith('es/') && !p.data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const services = (await getCollection('services', (s) => s.id.startsWith('es/')))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const readingMinutes = (content: string) =>
  Math.max(1, Math.round(content.split(/\s+/).length / 200));

const stripLocale = (id: string) => id.replace(/^es\//, '');
---
<BaseLayout title="Marco Sánchez Sorondo — Desarrollo, investigación, consultoría y capacitaciones de IA" description={tr('home.heroSub')}>
  <Hero
    title={tr('home.heroLine')}
    lead={tr('home.heroSub')}
    ctaPrimary={{ href: route(lang, 'services'), label: tr('cta.schedule') }}
    ctaSecondary={{ href: route(lang, 'blog'), label: tr('cta.readBlog') }}
  />

  <section class="max-w-container mx-auto px-4 py-12 grid md:grid-cols-2 lg:grid-cols-4 gap-8 border-t border-line">
    {[
      { label: tr('home.pillarDevelopment'), body: 'Plataformas, agentes y sistemas multimodales. Construyo en Intuitiv AI y OpuLens.' },
      { label: tr('home.pillarResearch'), body: 'IA generativa, computer vision y agentes en la Universidad Austral. Trabajo de frontera con aplicaciones reales.' },
      { label: tr('home.pillarConsulting'), body: 'Diagnóstico, auditorías, roadmap, implementación y acompañamiento para empresas que quieren adoptar IA.' },
      { label: tr('home.pillarTeaching'), body: 'Profesor en Austral, JTP en UBA. Programas in-house para equipos técnicos y de negocio.' }
    ].map(p => (
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-ink-mute">{p.label}</p>
        <p class="mt-2 text-ink-soft">{p.body}</p>
      </div>
    ))}
  </section>

  <section class="border-t border-line">
    <div class="max-w-container mx-auto px-4 py-20 md:py-28 text-center">
      <h2 class="font-display text-3xl md:text-5xl leading-tight max-w-3xl mx-auto">
        ¿Querés implementar tu idea o startup y no sabés cómo hacerlo ni por dónde empezar?
      </h2>
      <p class="mt-6 text-lg text-ink-soft max-w-2xl mx-auto leading-relaxed">
        Trabajo por proyecto. Mandame un mail con tu idea, presupuesto estimado y plazos. Si encaja, armamos el proyecto.
      </p>
      <p class="mt-8 text-base">
        → <a href="#" data-mail="bXNzb3JvbmRvbTAwQGdtYWlsLmNvbQ==" class="underline underline-offset-4 hover:text-ink">Email</a>
      </p>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="max-w-container mx-auto px-4 py-16 border-t border-line">
      <SectionTitle title={tr('home.featuredProjects')} />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map(p => (
          <ProjectCard
            name={p.data.name}
            tagline={p.data.tagline}
            status={p.data.status}
            href={localizedPath(lang, `proyectos/${stripLocale(p.id)}`)}
            stack={p.data.stack}
          />
        ))}
      </div>
    </section>
  )}

  {posts.length > 0 && (
    <section class="max-w-container mx-auto px-4 py-16 border-t border-line">
      <SectionTitle title={tr('home.latestPosts')} />
      <div>
        {posts.map(p => (
          <BlogCard
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            category={p.data.category}
            href={localizedPath(lang, `blog/${stripLocale(p.id)}`)}
            readingMinutes={readingMinutes(p.body ?? '')}
          />
        ))}
      </div>
    </section>
  )}

  {services.length > 0 && (
    <section class="max-w-container mx-auto px-4 py-16 border-t border-line">
      <SectionTitle title={tr('home.servicesPreview')} />
      <div class="grid md:grid-cols-2 gap-6">
        {services.map(s => (
          <ServiceCard
            title={s.data.title}
            audience={s.data.audience}
            includes={s.data.includes}
          />
        ))}
      </div>
    </section>
  )}

  <LogoStrip
    label={tr('home.orgsStrip')}
    orgs={[
      { name: 'Universidad Austral' },
      { name: 'UBA' },
      { name: 'Intuitiv AI' },
      { name: 'Peak Health' }
    ]}
  />

  <ContactBlock bordered />
</BaseLayout>
