---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Trabajemos juntos - Marco Sánchez Sorondo"
  description="Aplicación para construir tu idea o startup de IA end-to-end con Marco Sánchez Sorondo."
>
  <header>
    <p><a href="/es/">Marco Sánchez Sorondo</a> / aplicar / <a href="/en/apply/">EN</a></p>
    <h1>Trabajemos juntos</h1>
    <p>
      Contame qué querés construir. Trabajo por proyecto, con alcance, presupuesto y plazos
      definidos. Si buscás horas sueltas de un freelancer, no soy la persona.
    </p>
  </header>
  <main>
    <hr />
    <form action="https://formspree.io/f/xgoqklop" method="POST">
      <input type="hidden" name="_next" value="https://mszsorondo.github.io/es/gracias/" />
      <input type="hidden" name="_subject" value="Nueva aplicación - sitio personal" />

      <div>
        <label for="name">Nombre *</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div>
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div>
        <label for="idea">Tu idea o proyecto *</label>
        <textarea
          id="idea"
          name="idea"
          rows="6"
          required
          placeholder="Qué querés construir, qué problema resuelve, en qué etapa estás."
        ></textarea>
      </div>

      <fieldset>
        <legend>Presupuesto estimado *</legend>
        <label><input type="radio" name="budget" value="< USD 5K" required /> Menos de USD 5K</label>
        <label><input type="radio" name="budget" value="USD 5K - 15K" /> USD 5K - 15K</label>
        <label><input type="radio" name="budget" value="USD 15K - 50K" /> USD 15K - 50K</label>
        <label><input type="radio" name="budget" value="USD 50K+" /> USD 50K+</label>
      </fieldset>

      <fieldset>
        <legend>Cuándo querés arrancar *</legend>
        <label><input type="radio" name="timeline" value="Ya / próximas semanas" required /> Ya o en las próximas semanas</label>
        <label><input type="radio" name="timeline" value="Próximos 3 meses" /> Próximos 3 meses</label>
        <label><input type="radio" name="timeline" value="Más de 3 meses / explorando" /> Más de 3 meses o sigo explorando</label>
      </fieldset>

      <div>
        <label for="extra">¿Algo más?</label>
        <textarea
          id="extra"
          name="extra"
          rows="3"
          placeholder="Equipo, contexto, links de referencia, lo que quieras agregar."
        ></textarea>
      </div>

      <button type="submit">Enviar aplicación →</button>
    </form>
  </main>
</BaseLayout>
