---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import '../../styles/prose.css';

const pubs = (await getCollection('publications', (p) => p.id.startsWith('es/')))
  .sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title="Acerca — Marco Sánchez Sorondo">
  <section class="max-w-prose mx-auto px-4 py-16">
    <img src="/placeholder-photo.svg" alt="Marco Sánchez Sorondo" class="w-48 h-48 rounded-full object-cover border border-line mb-8" />
    <h1 class="font-display">Acerca</h1>
    <div class="prose mt-6">
      <p>Investigador e ingeniero en IA, en la intersección entre investigación académica y emprendimiento aplicado. Licenciado en Ciencias de la Computación por la UBA.</p>
      <p>Hoy trabajo como <strong>Investigador y Docente en IA Generativa & Computer Vision</strong> en la Universidad Austral, <strong>AI Engineer</strong> en Peak Health (getpeakhealth.com), y <strong>cofundador</strong> de Intuitiv AI (consultora de IA, ya rentable), OpuLens Vision Technologies (IA multimodal) y Arnium (infraestructura de IA).</p>
      <p>Publiqué en <strong>ICAPS 2023</strong> sobre exploration policies para controller synthesis — un trabajo en la intersección de métodos formales y deep learning. Sigo colaborando con el Software Engineering Lab de la UBA. En paralelo, doy clases de Algoritmos y Estructuras de Datos en la UBA desde 2022.</p>
      <p>Trabajo cómodo desde sistemas de bajo nivel (x86-64 ASM, kernels, FPGAs) hasta tooling de frontera para LLMs (LangChain, LangGraph, HuggingFace).</p>
      <p>Intereses de investigación: <em>Large Language Models, Reinforcement Learning, Graph Neural Networks, sistemas escalables de IA, IA segura y responsable (alignment, robustez, confiabilidad)</em>, y aplicaciones de ML en optimización, networks y decision-making.</p>
    </div>
  </section>

  <section class="max-w-prose mx-auto px-4 pb-12">
    <SectionTitle eyebrow="Distinciones y actividades" title="Liderazgo, premios y comunidad" />
    <ul class="space-y-4 text-ink-soft">
      <li><strong>1er puesto, Facebook Hack en Español 2022</strong> — competencia de programación de Meta, ganada con margen significativo en equipo "Perseverance Again".</li>
      <li><strong>Sponsor & Finance Chair — LXAI Workshop, NeurIPS 2025</strong> (accel.ai, San Diego). Misma rol que en NeurIPS 2023 (New Orleans): captación de sponsors, planificación financiera y logística del workshop.</li>
      <li><strong>Sponsor & Finance Chair — LXAI Workshop, NeurIPS 2023</strong> (accel.ai, New Orleans).</li>
      <li><strong>UN Youth Symposium</strong> (Naciones Unidas y Pontifical Academy of Sciences) — participante seleccionado tres años consecutivos (2019, 2020, 2021) sobre "Inter-generational Leadership for Sustainable Development".</li>
    </ul>
  </section>

  {pubs.length > 0 && (
    <section class="max-w-container mx-auto px-4 py-16 border-t border-line">
      <SectionTitle title="Publicaciones" />
      {pubs.map(p => (
        <PublicationCard {...p.data} />
      ))}
    </section>
  )}
</BaseLayout>
