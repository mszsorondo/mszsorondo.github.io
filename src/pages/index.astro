---
const target = '/es/';
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Marco Sánchez Sorondo</title>
    <script is:inline define:vars={{ target }}>
      location.replace(target);
    </script>
  </head>
  <body>
    <p>Redirigiendo a <a href={target}>{target}</a>…</p>
  </body>
</html>
