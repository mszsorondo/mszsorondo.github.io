---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { contact } from '../../lib/contact';

const posts = (await getCollection('blog', (p) => p.id.startsWith('en/') && !p.data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const mail64 = Buffer.from(contact.email).toString('base64');
const tel64 = Buffer.from(contact.phoneTel).toString('base64');
const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'UTC' });
---
<BaseLayout
  title="Marco Sánchez Sorondo"
  description="I build complex, reliable software and AI systems end to end, and ship them to production fast."
>
  <header>
    <h1>Marco Sánchez Sorondo</h1>
    <p><strong>I build complex, reliable software and AI systems end to end, and ship them to production fast.</strong></p>
    <p>
      Computer Scientist. AI Engineer &amp; Consultant. Cofounder of
      <a href="https://intuitiv-ai.com">Intuitiv AI</a>. Researcher and professor of AI at the
      School of Engineering @ Universidad Austral.
    </p>
    <p>
      <a data-mail={mail64} href="#">email</a> ·
      <a data-tel={tel64} data-tel-display={contact.phoneDisplay} href="#">phone</a>
    </p>
    <nav aria-label="Links">
      <p>
        <a href="/en/blog/">Blog</a> /
        <a href={contact.github}>GitHub</a> /
        <a href={contact.linkedin}>LinkedIn</a> /
        <a href="/es/">ES</a>
      </p>
    </nav>
  </header>

  <main>
    <hr />
    <section id="what-i-do">
      <h2>What I do</h2>
      <h3>Development &amp; Consulting</h3>
      <p>
        I develop platforms, AI agents, and end-to-end systems: design, implementation,
        deployment, and support. I work with companies across several sectors: healthcare,
        agriculture, finance, retail, law and accounting firms.
      </p>
      <p>
        Intensive process assessments, planning, implementation of custom developments,
        tool adoption.
      </p>
      <h3>Research</h3>
      <p>
        I research generative AI, computer vision, and agents at Universidad Austral, with
        applications in healthcare and media analysis. I take what works in the lab into
        client projects.
      </p>
      <h3>Training</h3>
      <p>
        I teach your team how AI works and everything they can do with it: prompting, agents,
        automations, and AI-assisted development, applied to their day-to-day work. The goal
        is that each person automates the repetitive parts and multiplies their output. I
        teach at Universidad Austral and IAE Business School; I adapt in-house programs to
        each team's stack and level.
      </p>
    </section>

    <hr />
    <section id="approach">
      <h2>Approach</h2>
      <p>
        Most AI projects die between the demo and production. Anyone can build a demo in a
        week; a system that survives real users, dirty data, and model errors is a different
        level of work. That work is my specialty.
      </p>
      <p>
        You pick the technology after you understand the problem. Many companies buy AI tools
        with no prior diagnosis and pile up software nobody uses. Diagnosis first, stack second.
      </p>
      <p>
        I work per project, with defined scope, budget, and deadlines. If you want loose
        freelancer hours, I'm the wrong person.
      </p>
    </section>

    <hr />
    <section id="what-i-built">
      <h2>What I've built</h2>
      <ul>
        <li>
          <strong><a href="https://intuitiv-ai.com">Intuitiv AI</a></strong>
          <p>AI consulting and development firm I cofounded, with clients across several
          industries. I built and operate platform.intuitiv-ai.com; I do solution design,
          engineering, agents, and infrastructure.</p>
        </li>
        <li>
          <strong><a href="https://clofi.com.ar">Clofi</a></strong>
          <p>Training management platform for coaches, gyms, and studios: routines, nutrition,
          progress tracking, messaging, and payments (MercadoPago, Stripe) in one place. I
          built it end to end: web, iOS, and Android apps.</p>
        </li>
        <li>
          <strong><a href="https://getpeakhealth.com">Peak Health</a></strong>
          <p>Medical agents supervised by real professionals (doctor-in-the-loop) and the
          backend of a healthcare platform under medical regulation. I designed and built the
          agents and the end-to-end model integration.</p>
        </li>
        <li>
          <strong><a href="https://opulens.technology">OpuLens</a></strong>
          <p>Multimodal AI platform: visual, audio, and text analysis in one system, with 17
          edge nodes across 6 continents and a zero-trust architecture.</p>
        </li>
        <li>
          <strong><a href="https://taskue.io">Taskue</a></strong>
          <p>A local-first, keyboard-driven to-do list. No accounts, no servers: your data
          never leaves your device.</p>
        </li>
        <li>
          <strong>MTSApy</strong>
          <p>API that integrates the MTSA controller synthesizer with PyTorch and TensorFlow,
          built at UBA's Software Engineering Lab.</p>
        </li>
      </ul>
    </section>

    <hr />
    <section id="track-record">
      <h2>Track record</h2>
      <ul class="rows">
        <li><span class="when">2025-</span> Researcher and professor, generative AI &amp; computer vision - Universidad Austral</li>
        <li><span class="when">2025-2026</span> AI engineer &amp; platform developer - Peak Health</li>
        <li><span class="when">2025-</span> Cofounder, AI &amp; platform engineer - Intuitiv AI</li>
        <li><span class="when">2024-</span> Independent consultant, technology &amp; AI</li>
        <li><span class="when">2022-2025</span> Teaching assistant, Algorithms and Data Structures I - UBA</li>
        <li><span class="when">2022-2023</span> Research intern, Software Engineering Lab (ICC) - UBA</li>
      </ul>
      <p>
        1st place, Facebook Hack en Español 2022 (Meta). Sponsor &amp; finance chair of the
        LXAI Workshop at NeurIPS 2023 and 2025.
      </p>
    </section>

    {posts.length > 0 && (
      <>
        <hr />
        <section id="blog">
          <h2>Blog</h2>
          <ul class="rows">
            {posts.map((p) => (
              <li>
                <span class="when">{fmt.format(p.data.pubDate)}</span>{' '}
                <a href={`/en/blog/${p.id.replace(/^en\//, '')}/`}>{p.data.title}</a>
              </li>
            ))}
          </ul>
          <p><a href="/en/rss.xml">RSS</a></p>
        </section>
      </>
    )}

    <hr />
    <section id="work-with-me">
      <h2>Work with me</h2>
      <p>
        Do you have an idea, a startup, or a company that wants to adopt AI? Tell me what you
        need.
      </p>
      <p>
        <a class="cta" href="/en/apply/">→ Apply here</a>
      </p>
      <p>
        Or write to me: <a data-mail={mail64} href="#">email</a> ·
        <a data-tel={tel64} data-tel-display={contact.phoneDisplay} href="#">phone</a>
      </p>
    </section>
  </main>
</BaseLayout>
