---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Testimonial from '../../components/Testimonial.astro';
import FAQ from '../../components/FAQ.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/utils';

const lang = 'en' as const;
const tr = t(lang);

const services = (await getCollection('services', (s) => s.id.startsWith('en/')))
  .sort((a, b) => a.data.order - b.data.order);
const testimonials = await getCollection('testimonials', (t) => t.id.startsWith('en/'));

const faqItems = [
  { q: 'What kind of companies do you take on?', a: 'Startups, scale-ups, and mid-size companies where someone owns the problem and can decide fast.' },
  { q: 'Do you work with remote teams?', a: 'Yes, most of my clients are outside Argentina. I work asynchronously with scheduled syncs.' },
  { q: 'Do you run corporate trainings?', a: "Yes, I tailor programs to internal stacks and team level. Typically 1-3 days on-site or spread across weekly sessions." },
  { q: 'How do you invoice?', a: 'USD invoicing for clients outside AR, local invoice in Argentina. 1:1 consulting mandates go under my personal name.' },
];
---
<BaseLayout title="Let's work together — Marco Sánchez Sorondo" description={tr('services.pageLead')}>
  <section class="max-w-container mx-auto px-4 py-16">
    <SectionTitle eyebrow="Services" title={tr('services.pageTitle')} subtitle={tr('services.pageLead')} />
    <div class="grid md:grid-cols-2 gap-6 mt-10">
      {services.map(s => (
        <ServiceCard
          title={s.data.title}
          audience={s.data.audience}
          includes={s.data.includes}
        />
      ))}
      {services.length === 0 && <p class="text-ink-mute col-span-full">Coming soon.</p>}
    </div>
  </section>

  <section class="border-t border-line">
    <ContactBlock
      title="Interested in any of these?"
      subtitle="Write to me and let's talk."
    />
  </section>

  {testimonials.length > 0 && (
    <section class="max-w-container mx-auto px-4 py-16 border-t border-line">
      <SectionTitle title={tr('services.testimonialsTitle')} />
      <div class="grid md:grid-cols-2 gap-6">
        {testimonials.slice(0, 4).map(tst => <Testimonial {...tst.data} />)}
      </div>
    </section>
  )}

  <FAQ items={faqItems} title={tr('services.faqTitle')} />
</BaseLayout>
