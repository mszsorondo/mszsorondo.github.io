---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Thanks — Marco Sánchez Sorondo"
  description="I received your application."
>
  <section class="max-w-prose mx-auto px-4 py-24 text-center">
    <p class="text-xs uppercase tracking-[0.2em] text-ink-mute mb-6">Application received</p>
    <h1 class="font-display text-4xl md:text-5xl leading-tight">Thanks!</h1>
    <p class="mt-6 text-lg text-ink-soft max-w-xl mx-auto leading-relaxed">
      I got your application. You'll hear from me within 48 hours with next steps.
    </p>
    <p class="mt-10 text-sm">
      <a href="/en/" class="underline underline-offset-4 hover:text-ink">← Back to home</a>
    </p>
  </section>
</BaseLayout>
