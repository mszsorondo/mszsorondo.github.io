---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Let's work together - Marco Sánchez Sorondo"
  description="Application to build your AI idea or startup end to end with Marco Sánchez Sorondo."
>
  <header>
    <p><a href="/en/">Marco Sánchez Sorondo</a> / apply / <a href="/es/aplicar/">ES</a></p>
    <h1>Let's work together</h1>
    <p>
      Tell me what you want to build. I work per project, with defined scope, budget, and
      deadlines. If you want loose freelancer hours, I'm the wrong person.
    </p>
  </header>
  <main>
    <hr />
    <form action="https://formspree.io/f/xgoqklop" method="POST">
      <input type="hidden" name="_next" value="https://mszsorondo.github.io/en/thanks/" />
      <input type="hidden" name="_subject" value="New application - personal site" />

      <div>
        <label for="name">Name *</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div>
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div>
        <label for="idea">Your idea or project *</label>
        <textarea
          id="idea"
          name="idea"
          rows="6"
          required
          placeholder="What you want to build, which problem it solves, what stage you're at."
        ></textarea>
      </div>

      <fieldset>
        <legend>Estimated budget *</legend>
        <label><input type="radio" name="budget" value="< USD 5K" required /> Under USD 5K</label>
        <label><input type="radio" name="budget" value="USD 5K - 15K" /> USD 5K - 15K</label>
        <label><input type="radio" name="budget" value="USD 15K - 50K" /> USD 15K - 50K</label>
        <label><input type="radio" name="budget" value="USD 50K+" /> USD 50K+</label>
      </fieldset>

      <fieldset>
        <legend>When do you want to start *</legend>
        <label><input type="radio" name="timeline" value="Now / next few weeks" required /> Now or in the next few weeks</label>
        <label><input type="radio" name="timeline" value="Next 3 months" /> Next 3 months</label>
        <label><input type="radio" name="timeline" value="3+ months / exploring" /> 3+ months or still exploring</label>
      </fieldset>

      <fieldset>
        <legend>How soon do you want the project finished *</legend>
        <label><input type="radio" name="duration" value="1 week" required /> 1 week</label>
        <label><input type="radio" name="duration" value="2-4 weeks" /> 2 to 4 weeks</label>
        <label><input type="radio" name="duration" value="1-3 months" /> 1 to 3 months</label>
        <label><input type="radio" name="duration" value="3-6 months" /> 3 to 6 months</label>
        <label><input type="radio" name="duration" value="I don't know yet" /> I don't know yet</label>
      </fieldset>

      <div>
        <label for="extra">Anything else?</label>
        <textarea
          id="extra"
          name="extra"
          rows="3"
          placeholder="Team, context, reference links, anything you want to add."
        ></textarea>
      </div>

      <button type="submit">Send application →</button>
    </form>
  </main>
</BaseLayout>
