---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionTitle from '../../../components/SectionTitle.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', (p) => p.id.startsWith('en/')))
  .sort((a, b) => a.data.order - b.data.order);

const stripLocale = (id: string) => id.replace(/^en\//, '');
---
<BaseLayout title="Projects — Marco Sánchez Sorondo">
  <section class="max-w-container mx-auto px-4 py-16">
    <SectionTitle eyebrow="Ventures" title="Projects" subtitle="What I build, alone or with teams." />
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map(p => (
        <ProjectCard
          name={p.data.name}
          tagline={p.data.tagline}
          status={p.data.status}
          href={`/en/projects/${stripLocale(p.id)}/`}
          stack={p.data.stack}
        />
      ))}
      {projects.length === 0 && <p class="text-ink-mute col-span-full">Coming soon.</p>}
    </div>
  </section>
</BaseLayout>
