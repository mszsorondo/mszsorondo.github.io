---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    category: string;
  };
  readingMinutes: number;
}
const { frontmatter, readingMinutes } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const fmt = new Intl.DateTimeFormat(lang === 'es' ? 'es-AR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.pubDate.toISOString(),
  inLanguage: lang === 'es' ? 'es-AR' : 'en-US',
  articleSection: frontmatter.category,
  author: { '@type': 'Person', name: 'Marco Sánchez Sorondo' },
  url: new URL(Astro.url.pathname, Astro.site).toString(),
};
---
<BaseLayout title={frontmatter.title} description={frontmatter.description} jsonLd={articleSchema}>
  <header>
    <p>
      <a href={`/${lang}/`}>Marco Sánchez Sorondo</a> /
      <a href={`/${lang}/blog/`}>blog</a>
    </p>
  </header>
  <main>
    <article>
      <h1>{frontmatter.title}</h1>
      <p class="mute">
        <time datetime={frontmatter.pubDate.toISOString()}>{fmt.format(frontmatter.pubDate)}</time>
        · {frontmatter.category} · {readingMinutes} min
      </p>
      <hr />
      <slot />
    </article>
  </main>
</BaseLayout>
