---
import { getLangFromUrl, t, getAltUrl, route, localizedPath } from '../i18n/utils';
import RingMark from './RingMark.astro';
import LanguageToggle from './islands/LanguageToggle.tsx';

const lang = getLangFromUrl(Astro.url);
const tr = t(lang);
const altLang: 'es' | 'en' = lang === 'es' ? 'en' : 'es';
const altUrl = getAltUrl(Astro.url, altLang);

const links = [
  { href: route(lang, 'about'), label: tr('nav.about') },
  { href: route(lang, 'work'), label: tr('nav.work') },
  { href: route(lang, 'projects'), label: tr('nav.projects') },
  { href: route(lang, 'services'), label: tr('nav.services') },
  { href: route(lang, 'blog'), label: tr('nav.blog') },
  { href: route(lang, 'contact'), label: tr('nav.contact') },
];
---
<header class="border-b border-line">
  <nav class="max-w-container mx-auto px-4 py-5 flex items-center justify-between">
    <a href={localizedPath(lang, '')} class="flex items-center gap-2 font-semibold tracking-wide">
      <span>Marco Sánchez Sorondo</span>
      <RingMark size={18} />
    </a>
    <ul class="hidden md:flex items-center gap-6 text-sm uppercase tracking-widest">
      {links.map(l => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
    <div class="flex items-center gap-3">
      <LanguageToggle client:load currentLang={lang} altUrl={altUrl} />
    </div>
  </nav>
</header>
