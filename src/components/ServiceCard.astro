---
interface Props {
  title: string;
  audience: string;
  includes: string[];
}
const { title, audience, includes } = Astro.props;
---
<article class="border border-line p-6 flex flex-col">
  <h3 class="font-display text-xl">{title}</h3>
  <p class="mt-2 text-sm uppercase tracking-widest text-ink-mute">{audience}</p>
  <ul class="mt-4 space-y-1 text-sm text-ink-soft flex-1">
    {includes.map(i => <li>· {i}</li>)}
  </ul>
</article>
