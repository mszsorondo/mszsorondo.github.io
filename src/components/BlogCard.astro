---
import { getLangFromUrl, t } from '../i18n/utils';
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  href: string;
  readingMinutes: number;
}
const { title, description, pubDate, category, href, readingMinutes } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const tr = t(lang);
const fmt = new Intl.DateTimeFormat(lang === 'es' ? 'es-AR' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="border-b border-line py-8">
  <div class="flex items-center gap-3 text-xs uppercase tracking-widest text-ink-mute mb-3">
    <time datetime={pubDate.toISOString()}>{fmt.format(pubDate)}</time>
    <span>·</span>
    <span>{category}</span>
    <span>·</span>
    <span>{readingMinutes} {tr('blog.readingTime')}</span>
  </div>
  <h3 class="font-display text-2xl">
    <a href={href} class="hover:underline underline-offset-4">{title}</a>
  </h3>
  <p class="mt-3 text-ink-soft max-w-prose">{description}</p>
</article>
