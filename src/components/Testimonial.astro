---
interface Props {
  quote: string;
  author: string;
  role: string;
  company: string;
  avatar?: string;
}
const { quote, author, role, company, avatar } = Astro.props;
---
<figure class="border border-line p-6">
  <blockquote class="font-display text-xl leading-snug">"{quote}"</blockquote>
  <figcaption class="mt-4 flex items-center gap-3">
    {avatar && <img src={avatar} alt="" class="w-10 h-10 rounded-full object-cover" />}
    <div>
      <p class="font-semibold text-sm">{author}</p>
      <p class="text-xs text-ink-mute">{role} · {company}</p>
    </div>
  </figcaption>
</figure>
