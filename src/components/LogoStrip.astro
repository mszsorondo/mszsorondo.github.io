---
interface Props { label?: string; orgs: { name: string; url?: string }[]; }
const { label, orgs } = Astro.props;
---
<section class="max-w-container mx-auto px-4 py-16">
  {label && <p class="text-xs uppercase tracking-[0.2em] text-ink-mute text-center mb-8">{label}</p>}
  <ul class="flex flex-wrap justify-center gap-x-10 gap-y-4 text-sm text-ink-soft">
    {orgs.map(o => (
      <li>
        {o.url ? <a href={o.url} class="hover:text-ink" target="_blank" rel="noopener">{o.name}</a> : o.name}
      </li>
    ))}
  </ul>
</section>
