---
interface Props {
  name: string;
  tagline: string;
  status: 'idea' | 'wip' | 'production' | 'launched';
  href: string;
  stack?: string[];
}
const { name, tagline, status, href, stack = [] } = Astro.props;
const statusLabel: Record<string, string> = { idea: 'Idea', wip: 'WIP', production: 'Producción', launched: 'Lanzado' };
---
<a href={href} class="block border border-line p-6 md:p-8 group hover:border-ink transition-colors h-full flex flex-col bg-paper">
  <span class="text-xs uppercase tracking-[0.2em] text-ink-mute mb-4">{statusLabel[status]}</span>
  <h3 class="font-display text-2xl md:text-3xl leading-tight group-hover:underline underline-offset-4 min-h-[3rem]">{name}</h3>
  <p class="mt-3 text-ink-soft leading-relaxed flex-1">{tagline}</p>
  {stack.length > 0 && (
    <ul class="mt-6 pt-4 border-t border-line flex flex-wrap gap-x-3 gap-y-1">
      {stack.slice(0, 5).map(s => <li class="text-xs uppercase tracking-widest text-ink-mute">{s}</li>)}
    </ul>
  )}
</a>
