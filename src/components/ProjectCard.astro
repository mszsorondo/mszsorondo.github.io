---
interface Props {
  name: string;
  tagline: string;
  status: 'idea' | 'wip' | 'production' | 'launched';
  href: string;
  stack?: string[];
}
const { name, tagline, status, href, stack = [] } = Astro.props;
const statusLabel: Record<string, string> = { idea: 'Idea', wip: 'WIP', production: 'Producción', launched: 'Lanzado' };
---
<a href={href} class="block border border-line p-6 group hover:border-ink transition-colors">
  <div class="flex items-center justify-between mb-4">
    <span class="text-xs uppercase tracking-widest text-ink-mute">{statusLabel[status]}</span>
  </div>
  <h3 class="font-display text-2xl group-hover:underline underline-offset-4">{name}</h3>
  <p class="mt-3 text-ink-soft">{tagline}</p>
  {stack.length > 0 && (
    <ul class="mt-4 flex flex-wrap gap-2">
      {stack.slice(0, 5).map(s => <li class="text-xs text-ink-mute">{s}</li>)}
    </ul>
  )}
</a>
