---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  role: string;
  org: string;
  startDate: Date;
  endDate: Date | null;
  kind: 'research' | 'applied' | 'teaching';
  bullets: string[];
  location: string;
}
const { role, org, startDate, endDate, kind, bullets, location } = Astro.props;

const lang = getLangFromUrl(Astro.url);

const fmt = (d: Date) =>
  d.toLocaleDateString(lang === 'es' ? 'es-AR' : 'en-US', { year: 'numeric', month: 'short' });

const kindLabels = {
  es: { research: 'Investigación', applied: 'Aplicado', teaching: 'Docencia' },
  en: { research: 'Research', applied: 'Applied', teaching: 'Teaching' },
} as const;

const presentLabel = lang === 'es' ? 'Presente' : 'Present';
---
<article class="border-l border-line pl-6 pb-10 relative">
  <span class="absolute -left-[5px] top-1 w-2.5 h-2.5 bg-ink rounded-full" aria-hidden="true"></span>
  <p class="text-xs uppercase tracking-widest text-ink-mute">{fmt(startDate)} — {endDate ? fmt(endDate) : presentLabel} · {kindLabels[lang][kind]} · {location}</p>
  <h3 class="font-display text-xl mt-2">{role}</h3>
  <p class="text-ink-soft">{org}</p>
  <ul class="mt-3 space-y-1 text-sm list-disc list-inside marker:text-ink-mute">
    {bullets.map(b => <li>{b}</li>)}
  </ul>
</article>
