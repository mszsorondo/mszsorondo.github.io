---
import { contact } from '../lib/contact';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  subtitle?: string;
  showLinkedIn?: boolean;
  showGitHub?: boolean;
  bordered?: boolean;
}
const lang = getLangFromUrl(Astro.url);
const {
  title = lang === 'es' ? 'Contacto' : 'Contact',
  subtitle,
  showLinkedIn = true,
  showGitHub = true,
  bordered = false,
} = Astro.props;

const emailB64 = Buffer.from(contact.email).toString('base64');
const emailAltB64 = Buffer.from(contact.emailAlt).toString('base64');
const phoneB64 = Buffer.from(contact.phoneTel).toString('base64');

const wrapperClass = bordered
  ? 'border-t border-line mt-16 py-16'
  : 'py-12';
---
<section class={wrapperClass}>
  <div class="max-w-container mx-auto px-4 grid md:grid-cols-[1fr_2fr] gap-10 items-start">
    <div>
      <h2 class="font-display text-3xl">{title}</h2>
      {subtitle && <p class="mt-3 text-ink-soft text-lg">{subtitle}</p>}
    </div>
    <ul class="space-y-4 text-xl">
      <li class="flex items-baseline gap-3">
        <span class="text-xs uppercase tracking-widest text-ink-mute w-24 shrink-0">Email</span>
        <a class="underline underline-offset-4 hover:text-ink-soft" href="#" data-mail={emailB64} aria-label="Email principal">Email</a>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="text-xs uppercase tracking-widest text-ink-mute w-24 shrink-0">Email alt.</span>
        <a class="underline underline-offset-4 hover:text-ink-soft" href="#" data-mail={emailAltB64} aria-label="Email alternativo">Email</a>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="text-xs uppercase tracking-widest text-ink-mute w-24 shrink-0">{lang === 'es' ? 'Teléfono' : 'Phone'}</span>
        <a class="underline underline-offset-4 hover:text-ink-soft" href="#" data-tel={phoneB64} data-tel-display={contact.phoneDisplay} aria-label="Teléfono">{lang === 'es' ? 'Teléfono' : 'Phone'}</a>
      </li>
      {showLinkedIn && (
        <li class="flex items-baseline gap-3">
          <span class="text-xs uppercase tracking-widest text-ink-mute w-24 shrink-0">LinkedIn</span>
          <a href={contact.linkedin} target="_blank" rel="noopener" class="underline underline-offset-4 hover:text-ink-soft">linkedin.com/in/marco-sanchez-sorondo</a>
        </li>
      )}
      {showGitHub && (
        <li class="flex items-baseline gap-3">
          <span class="text-xs uppercase tracking-widest text-ink-mute w-24 shrink-0">GitHub</span>
          <a href={contact.github} target="_blank" rel="noopener" class="underline underline-offset-4 hover:text-ink-soft">github.com/mszsorondo</a>
        </li>
      )}
    </ul>
  </div>
</section>
