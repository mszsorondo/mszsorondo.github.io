---
import { contact } from '../lib/contact';

interface Props {
  title?: string;
  subtitle?: string;
  showLinkedIn?: boolean;
  showGitHub?: boolean;
}
const { title, subtitle, showLinkedIn = true, showGitHub = true } = Astro.props;

const emailB64 = Buffer.from(contact.email).toString('base64');
const emailAltB64 = Buffer.from(contact.emailAlt).toString('base64');
const phoneB64 = Buffer.from(contact.phoneTel).toString('base64');
---
<section class="max-w-prose mx-auto px-4 py-12">
  {title && <h2 class="font-display">{title}</h2>}
  {subtitle && <p class="mt-3 text-ink-soft">{subtitle}</p>}
  <ul class="mt-6 space-y-3 text-lg">
    <li>
      <a class="underline underline-offset-4" href="#" data-mail={emailB64} aria-label="Email principal">Email</a>
    </li>
    <li>
      <a class="underline underline-offset-4" href="#" data-mail={emailAltB64} aria-label="Email alternativo">Email alternativo</a>
    </li>
    <li>
      <a class="underline underline-offset-4" href="#" data-tel={phoneB64} data-tel-display={contact.phoneDisplay} aria-label="Teléfono">Teléfono</a>
    </li>
    {showLinkedIn && (
      <li>
        <a href={contact.linkedin} target="_blank" rel="noopener" class="underline underline-offset-4">LinkedIn</a>
      </li>
    )}
    {showGitHub && (
      <li>
        <a href={contact.github} target="_blank" rel="noopener" class="underline underline-offset-4">GitHub</a>
      </li>
    )}
  </ul>
</section>
