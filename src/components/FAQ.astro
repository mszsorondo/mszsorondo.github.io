---
interface Props {
  items: { q: string; a: string }[];
  title?: string;
}
const { items, title } = Astro.props;
---
<section class="max-w-prose mx-auto px-4 py-16">
  {title && <h2 class="font-display mb-8">{title}</h2>}
  <ul class="space-y-4">
    {items.map(({ q, a }) => (
      <li>
        <details class="border-b border-line py-4 group">
          <summary class="cursor-pointer font-semibold flex items-center justify-between">
            <span>{q}</span>
            <span class="text-ink-mute group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-3 text-ink-soft">{a}</p>
        </details>
      </li>
    ))}
  </ul>
</section>
