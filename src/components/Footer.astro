---
import { getLangFromUrl, t, route, localizedPath } from '../i18n/utils';
import { contact } from '../lib/contact';

const lang = getLangFromUrl(Astro.url);
const tr = t(lang);
const year = new Date().getFullYear();
const emailB64 = Buffer.from(contact.email).toString('base64');
---
<footer class="mt-24 border-t border-line">
  <div class="max-w-container mx-auto px-4 py-12 grid gap-8 md:grid-cols-3">
    <div>
      <a href={localizedPath(lang, '')} class="font-semibold tracking-tight">
        Marco Sánchez Sorondo
      </a>
      <p class="mt-3 text-sm text-ink-mute">Buenos Aires, Argentina</p>
    </div>

    <nav class="text-sm space-y-2">
      <a class="block hover:underline" href={route(lang, 'about')}>{tr('nav.about')}</a>
      <a class="block hover:underline" href={route(lang, 'projects')}>{tr('nav.projects')}</a>
      <a class="block hover:underline" href={route(lang, 'services')}>{tr('nav.services')}</a>
      <a class="block hover:underline" href={route(lang, 'blog')}>{tr('nav.blog')}</a>
    </nav>

    <div class="text-sm space-y-2">
      <a class="block hover:underline" href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a class="block hover:underline" href={contact.github} target="_blank" rel="noopener">GitHub</a>
      <a class="block hover:underline" href="#" data-mail={emailB64} aria-label="Email">Email</a>
      <a class="block hover:underline" href={lang === 'es' ? '/rss.xml' : '/en/rss.xml'}>RSS</a>
    </div>
  </div>
  <div class="border-t border-line">
    <div class="max-w-container mx-auto px-4 py-4 text-xs text-ink-mute flex justify-between">
      <span>© {year} Marco Sánchez Sorondo. {tr('footer.rights')}</span>
      <span>{lang.toUpperCase()}</span>
    </div>
  </div>
</footer>
