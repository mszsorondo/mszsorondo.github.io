---
import { getLangFromUrl } from '../i18n/utils';
interface Props { formActionUrl?: string; }
const { formActionUrl = 'https://buttondown.email/api/emails/embed-subscribe/mszsorondo' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const label = lang === 'es' ? 'Suscribite al newsletter' : 'Subscribe to the newsletter';
const sub = lang === 'es' ? 'Un post por semana sobre IA, construcción y enseñanza. Sin spam.' : 'One post a week on AI, building, and teaching. No spam.';
const placeholder = lang === 'es' ? 'tu@email.com' : 'your@email.com';
const button = lang === 'es' ? 'Suscribirme' : 'Subscribe';
---
<section class="max-w-prose mx-auto px-4 py-12 border-t border-line">
  <h3 class="font-display text-2xl">{label}</h3>
  <p class="mt-2 text-ink-soft">{sub}</p>
  <form action={formActionUrl} method="post" target="popupwindow" class="mt-4 flex flex-col sm:flex-row gap-2">
    <input type="email" name="email" required placeholder={placeholder} class="flex-1 border border-line px-3 py-2" />
    <button type="submit" class="bg-ink text-white px-6 py-2 text-xs uppercase tracking-widest font-semibold">{button}</button>
  </form>
  <p class="mt-3 text-xs text-ink-mute">{lang === 'es' ? 'Si el formulario falla, escribí a msorondo@live.com.ar' : "If the form fails, email msorondo@live.com.ar"}</p>
</section>
