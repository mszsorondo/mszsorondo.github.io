---
import { getLangFromUrl, t, route } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const tr = t(lang);
---
<aside class="max-w-container mx-auto px-4 my-16">
  <div class="border border-ink p-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div>
      <h3 class="font-display text-2xl">{lang === 'es' ? '¿Trabajamos juntos?' : 'Shall we work together?'}</h3>
      <p class="mt-2 text-ink-soft max-w-[50ch]">{lang === 'es' ? 'Agendá 30 minutos para contarme qué tenés en mente.' : 'Book 30 minutes to tell me what you have in mind.'}</p>
    </div>
    <a href={route(lang, 'services')} class="bg-ink text-paper px-6 py-3 text-xs uppercase tracking-[0.15em] font-semibold hover:opacity-90 whitespace-nowrap">
      {tr('cta.schedule')}
    </a>
  </div>
</aside>
